{
  "name": "weedoshi",
  "version": "1.0.0",
  "author": "Wondrej D. Grower & LLM's",
  "scripts": {
    "dev": "HOME=. EXPO_NO_TELEMETRY=1 expo start --clear",
    "android": "HOME=. EXPO_NO_TELEMETRY=1 expo start --android",
    "ios": "HOME=. EXPO_NO_TELEMETRY=1 expo start --ios",
    "build": "HOME=. EXPO_NO_TELEMETRY=1 expo export --platform web",
    "preview": "python3 -m http.server 4173 --bind 127.0.0.1 --directory dist",
    "lint": "test -x ./node_modules/.bin/eslint && ./node_modules/.bin/eslint -c .eslintrc.json app src App.tsx || (echo 'Install dependencies first: npm install' && exit 1)",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "rm -rf .test-dist && tsc -p tsconfig.tests.json && printf '{\"type\":\"module\"}' > .test-dist/package.json && mkdir -p .test-dist/node_modules/@react-native-async-storage/async-storage .test-dist/node_modules/expo-secure-store && cp tests/stubs-runtime/async-storage.js .test-dist/node_modules/@react-native-async-storage/async-storage/index.js && cp tests/stubs-runtime/expo-secure-store.js .test-dist/node_modules/expo-secure-store/index.js && node --experimental-specifier-resolution=node --test .test-dist/tests/unit/*.test.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.0.0",
    "@types/lru-cache": "^7.10.10",
    "expo": "~52.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-crypto": "~14.0.0",
    "expo-haptics": "~14.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.28.0",
    "expo-status-bar": "~2.0.0",
    "modern-screenshot": "^4.6.8",
    "nostr-tools": "^2.23.2",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^18.3.1",
    "@types/react-native": "^0.73.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint": "^8.55.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "expo": {
    "plugins": [
      "expo-router"
    ]
  }
}
