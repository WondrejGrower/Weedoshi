{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "@react-native-community",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "react",
    "react-native"
  ],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react-native/no-unused-styles": "warn",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prettier/prettier": "off",
    "react-hooks/exhaustive-deps": "warn"
  },
  "settings": {
    "react": {
      "version": "18.3"
    }
  }
}
